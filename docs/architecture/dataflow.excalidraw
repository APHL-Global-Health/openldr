    {
      "id": "ann_minio_feedback",
      "type": "text",
      "x": 862,
      "y": 1151,
      "width": 258.984375,
      "height": 146.25,
      "text": "Stores raw, validated, mapped,\nand processed files.\n\nMinIO bucket notifications\ntrigger Kafka topics per prefix:\n  • raw/ → raw-inbound\n  • validated/ → validated-inbound\n  • mapped/ → mapped-inbound\n  • storage/ → storage-inbound",
      "originalText": "Stores raw, validated, mapped,\nand processed files.\n\nMinIO bucket notifications\ntrigger Kafka topics per prefix:\n  • raw/ → raw-inbound\n  • validated/ → validated-inbound\n  • mapped/ → mapped-inbound\n  • storage/ → storage-inbound",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#dc2626",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
