# =============================================================================
# OpenLDR Deployment Configuration
# =============================================================================
# Copy this file to .env and update the values below before running:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# Docker Registry Configuration
# Set to your Docker Hub organization/username (e.g., myorg or myuser)
DOCKER_REGISTRY=openldr
IMAGE_TAG=latest

# =============================================================================
# General
# =============================================================================
COMPOSE_PROJECT_NAME=openldr
NODE_TLS_REJECT_UNAUTHORIZED=0
RUNNING_IN_CONTAINER=true
LOG_FILE_KEPT_NUMBER=5
DOCKER_HOST_IP=127.0.0.1
HOST_IP=127.0.0.1

# Set to false in production
INCLUDE_TEST_DATA=true

# Container Restrictions
CPU_LIMIT=0
MEMORY_LIMIT=512M
MEMORY_RESERVATIONS=128M
MEMSWAP_LIMIT=1G

# =============================================================================
# Gateway
# =============================================================================
GATEWAY_HTTP_PORT=8090
GATEWAY_HTTPS_PORT=443

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=openldr
POSTGRES_DB_EXTERNAL=openldr_external
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change-me>
POSTGRES_PORT=5432
POSTGRES_HOSTNAME=openldr-postgres

# pgAdmin Console
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=<change-me>
PGADMIN_CONFIG_SERVER_MODE=False
PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED=False

# =============================================================================
# Keycloak (SSO / Identity Management)
# =============================================================================
KEYCLOAK_PORT=8080
KEYCLOAK_INTERNAL_PORT=8080
KEYCLOAK_REALM=openldr-realm
KEYCLOAK_CLIENT_ID=openldr-client
KEYCLOAK_CLIENT_SECRET=<change-me>
KEYCLOAK_WEB_CLIENT_ID=ui-openldr-client
KEYCLOAK_BACKEND_CLIENT_ID=backend-openldr-client
KEYCLOAK_BACKEND_CLIENT_SECRET=<change-me>
KEYCLOAK_DB_PORT=3311
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<change-me>
KEYCLOAK_DB_ROOT_PASSWORD=root
KEYCLOAK_BASE_URL=https://openldr-keycloak:8443/keycloak
KEYCLOAK_PUBLIC_URL=https://127.0.0.1:443/keycloak
KEYCLOAK_CPU_LIMIT=
KEYCLOAK_MEMORY=
KEYCLOAK_HOSTNAME=openldr-keycloak

# =============================================================================
# MinIO (Object Storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<change-me>
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=https://127.0.0.1:443/minio-console/
MINIO_PUBLIC_URL=https://127.0.0.1:443/minio-console/
MINIO_HOSTNAME=openldr-minio
MINIO_FORCE_PATH_STYLE=false
MINIO_ENDPOINT=http://openldr-minio:9000
MINIO_REGION=us-east-1

# MinIO object lifecycle TTLs (days)
MINIO_TTL_RAW_DAYS=7
MINIO_TTL_VALIDATED_DAYS=3
MINIO_TTL_MAPPED_DAYS=3
MINIO_TTL_PROCESSED_DAYS=90
MINIO_TTL_SOURCES_DAYS=0

# =============================================================================
# Kafka (Message Streaming)
# =============================================================================
KAFKA_EXTERNAL_PORT=9094
KAFKA_DOCKER_PORT=29092
KAFKA_CONNECT_PORT=8083
KAFKA_CONDUKTOR_PORT=8082
KAFKA_CONDUKTOR_USERNAME=admin
KAFKA_CONDUKTOR_PASSWORD=<change-me>
KAFKA_CPU_LIMIT=
KAFKA_MEMORY=
KAFKA_HOSTNAME=openldr-kafka1
KAFKA_CONNECT_HOSTNAME=openldr-kafka-connect
KAFKA_CONDUKTOR_HOSTNAME=openldr-kafka-conduktor-console

# =============================================================================
# OpenSearch (Full-text Search)
# =============================================================================
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARD_PORT=5601
OPENSEARCH_CPU_LIMIT=
OPENSEARCH_MEMORY=
OPENSEARCH_HOSTNAME=openldr-opensearch
OPENSEARCH_DASHBORD_HOSTNAME=openldr-opensearch-dashboard

# =============================================================================
# Entity Services
# =============================================================================
ENTITY_SERVICES_PORT=3002
ENTITY_SERVICES_HOSTNAME=openldr-entity-services
ENTITY_SERVICES_PUBLIC_URL=https://127.0.0.1:443/entity-services

# Extension credential encryption (min 32 chars, AES-256-GCM)
CREDENTIAL_ENCRYPTION_KEY=<change-me-min-32-characters-long>

# =============================================================================
# Data Processing
# =============================================================================
DATA_PROCESSING_PORT=3001
DATA_PROCESSING_HOSTNAME=openldr-data-processing
DATA_PROCESSING_PUBLIC_URL=https://127.0.0.1:443/data-processing

# =============================================================================
# External Database
# =============================================================================
EXTERNAL_DATABASE_PORT=3009
EXTERNAL_DATABASE_HOSTNAME=openldr-external-database

# =============================================================================
# Web Frontend
# =============================================================================
WEB_HOSTNAME=openldr-web
WEB_PORT=3000

# =============================================================================
# Studio
# =============================================================================
STUDIO_HOSTNAME=openldr-studio
STUDIO_PORT=3000

# =============================================================================
# AI Service
# =============================================================================
AI_APP_NAME=openldr-ai
AI_APP_VERSION=0.1.0
AI_DEBUG=false
AI_HF_HOME=/app/ai
AI_MODELS_DIR=/app/ai
AI_CORS_ORIGINS=https://127.0.0.1:443,https://127.0.0.1:3000,http://127.0.0.1,http://127.0.0.1:3000,https://127.0.0.1:443/studio
AI_HOSTNAME=openldr-ai
AI_PORT=8100
AI_MCP_URL=http://openldr-mcp-server:6060
AI_DEFAULT_MODEL=LiquidAI/LFM2-1.2B-RAG
AI_MAX_INPUT_TOKENS=4096
AI_RESERVED_OUTPUT_TOKENS=768
AI_CONTEXT_SAFETY_MARGIN_TOKENS=256
AI_MAX_HISTORY_MESSAGES=6
AI_TOOL_RESULT_CHAR_LIMIT=3500
AI_MAX_TOOL_CALLS=2
